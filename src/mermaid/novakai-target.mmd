%% fm:meta blockEventStore i0.returns=void

%% ---- persistence ----
%% fm:meta documentStorage name=useDocumentStorage
%% fm:meta documentStorage desc=Supabase-backed persistence; debounced upsert; merges via a module-level cachedDoc
%% fm:meta documentStorage i0.name=loadDocument
%% fm:meta documentStorage i0.returns=Promise<DataSet | null>
%% fm:meta documentStorage i1.name=saveDocument
%% fm:meta documentStorage i1.accepts=files: FilesDataSet, content: ContentDataSet, layouts: LayoutDataSet, databases: DatabaseDataSet
%% fm:meta documentStorage i1.returns=void
