%% fm:meta copy i0.accepts=range: SelectionPoint[], shape: DocShape
%% fm:meta copy i0.returns=void
%% fm:meta cut name=cut
%% fm:meta cut desc=copies into the buffer then returns a DocShape with the source blocks removed
%% fm:meta cut i0.name=cut
%% fm:meta cut i0.accepts=range: SelectionPoint[], shape: DocShape
%% fm:meta cut i0.returns=DocShape
%% fm:meta paste name=paste
%% fm:meta paste desc=reads the buffer and routes to text-paste or block-paste; copy mints fresh ids, cut keeps them
%% fm:meta paste i0.name=paste
%% fm:meta paste i0.accepts=shape: DocShape, trigger: string
%% fm:meta paste i0.returns=DocShape
%% fm:meta clipboardBuffer name=clipboardBuffer
%% fm:meta clipboardBuffer desc=module-scoped clipboard slice (NOT a Zustand store, NOT document state); survives ClipboardManager rebuilds
%% fm:meta clipboardBuffer state=slice: ClipboardSlice | null
%% fm:meta clipboardBuffer state=mode: copy | cut | null

%% ---- Zustand stores (minimised: 14 reactive state vars total) ----
