  %% ---- spine (solid): real construction / call order ----
  main --> App
  App -->|1| LeftPanel
  App -->|2| Editor
  App -->|3| RightPanel
  Editor -->|1| Header
  Editor -->|2| WorkspaceArea
  Editor -->|3| Footer
  WorkspaceArea -->|1| blockManager
  WorkspaceArea -->|2| selectionManager
  WorkspaceArea -->|3| dragManager
  WorkspaceArea -->|4| layoutManager
  WorkspaceArea --> DragContainer
  DragContainer -->|handle| DragHandle
  DragContainer -->|text| ContentArea
  DragContainer -->|db| DatabaseArea
  DragContainer -->|canvas| CanvasArea
  DatabaseArea --> DatabaseRow
  DatabaseRow -->|text col| TextCell
  DatabaseRow -->|check col| CheckboxCell

  RightPanel -->|Style tile| Toolbar
  RightPanel -->|Appearance tile| AppearanceControls
  Toolbar -->|text selected| TextStyleControls
  Toolbar -->|block selected| BlockStyleControls
  Toolbar -->|db selected| DatabaseStyleControls

  LeftPanel --> Panel
  Panel -->|1| PanelHeader
  Panel -->|2| PanelBody
  Panel -->|3| PanelToggle
  PanelHeader --> PanelHeaderTile
  PanelBody --> PanelBodyItem

  blockManager -->|catalog| blockDefinitions
  blockManager -->|new database| databaseFactory
  blockManager -->|apply style| styleApplier
  selectionManager -->|1 route| selectionRouter
  selectionManager -->|2 span| range
  selectionManager -->|3 build shape| shapeBuilder
  selectionManager -->|4 paint| highlightRenderer
  selectionManager --> clipboardManager
  selectionRouter -->|caret| caretNavigation
  selectionRouter -->|extend| selectionExtend
  layoutManager -->|resolve| workspaceLayout
  workspaceLayout -->|collisions| collisionManager
  workspaceLayout -->|snap| grid
  clipboardManager -->|c| copy
  clipboardManager -->|x| cut
  clipboardManager -->|v| paste

  %% ---- references (dotted): wiring, reads, callbacks, write-backs ----
  App -.->|auth guard renders| Login
  App -.->|reads status| authStore
  App -.->|loads doc on sign-in| documentStorage
  App -.->|hydrates on sign-in| themeStore

  WorkspaceArea -.->|builds + threads| docDraft
  docDraft -.->|flattened to| docShape
  blockManager -.->|records new block ids| docDraft
  selectionManager -.->|reads new block ids, sets caret| docDraft
  WorkspaceArea -.->|seeds from + commits to| workspaceStore
  WorkspaceArea -.->|saves| documentStorage
  WorkspaceArea -.->|picks renderer| componentRegistry
  WorkspaceArea -.->|when empty| WorkspaceEmptyState
