%% Novakai — GOLD-STANDARD TARGET ARCHITECTURE (proposed)
%% Companion notes: novakai-target.md
%% This map describes what the codebase SHOULD look like: a fully working,
%% bug-free, shippable app. The WSA router (BM -> SM -> DM -> LM) is FROZEN
%% and unchanged. New/proposed classes are marked in novakai-target.md.
%% root main
%% Drill-in containment: each helper group lives INSIDE its manager. Click a
%% manager's "Open internals" button to see its helpers (one level down). The
%% top level stays at architecture altitude; helper detail is hidden until you
%% drill in. Groups are transparent for leveling, so the helpers report the
%% manager as their level.
%% parent blockHelpers blockManager
%% parent selectionHelpers selectionManager
%% parent layoutHelpers layoutManager
%% parent clipboardHelpers clipboardManager

%% ---- shell ----
%% fm:meta main name=main.tsx
%% fm:meta main desc=entry point; mounts React root in StrictMode
%% fm:meta main i0.name=render
%% fm:meta main i0.returns=void
%% fm:meta App name=App
%% fm:meta App desc=root component; constructs the four managers once in refs, guards auth, loads document + theme on sign-in
%% fm:meta App state=managers: ManagerSet (bm, sm, dm, lm) in refs
%% fm:meta App i0.name=render
%% fm:meta App i0.accepts=authStatus: loading | signed-in | signed-out
%% fm:meta App i0.returns=JSX (LeftPanel + Editor + RightPanel, or Login)
%% fm:meta Login name=Login
%% fm:meta Login desc=auth form; rendered only while authStatus is signed-out
%% fm:meta Login i0.name=render
%% fm:meta Login i0.returns=JSX

%% ---- side panels ----
%% fm:meta LeftPanel name=LeftPanel
%% fm:meta LeftPanel desc=container; file browser + block catalog; turns clicks into insert intents, never decides
%% fm:meta LeftPanel i0.name=handleAddFile
%% fm:meta LeftPanel i0.returns=void
%% fm:meta LeftPanel i1.name=handleInsertBlock
%% fm:meta LeftPanel i1.accepts=spec: BlockSpec
%% fm:meta LeftPanel i1.returns=void
%% fm:meta RightPanel name=RightPanel
%% fm:meta RightPanel desc=container; hosts two tiles via the shared panel kit: Style (Toolbar) and Appearance
%% fm:meta RightPanel i0.name=render
%% fm:meta RightPanel i0.returns=JSX

%% ---- toolbar (contextual styling) ----
%% fm:meta Toolbar name=Toolbar
%% fm:meta Toolbar desc=Style tile; resolves the current selection into ONE styling level and renders it; emits style intents, never mutates the document
%% fm:meta Toolbar state=level: text | block | database (DERIVED from selection, not stored)
%% fm:meta Toolbar i0.name=render
%% fm:meta Toolbar i0.accepts=selection: SelectionSnapshot
%% fm:meta Toolbar i0.returns=JSX (one StyleControls level)
%% fm:meta TextStyleControls name=TextStyleControls
%% fm:meta TextStyleControls desc=level 1; shown when a text run is selected; bold/italic, font, size, colour
%% fm:meta TextStyleControls i0.name=emit
%% fm:meta TextStyleControls i0.accepts=intent: StyleIntent
%% fm:meta TextStyleControls i0.returns=void
%% fm:meta BlockStyleControls name=BlockStyleControls
%% fm:meta BlockStyleControls desc=level 2; shown when whole blocks are selected; Tag (h1..p), alignment, background, width
%% fm:meta BlockStyleControls i0.name=emit
%% fm:meta BlockStyleControls i0.accepts=intent: StyleIntent
%% fm:meta BlockStyleControls i0.returns=void
%% fm:meta DatabaseStyleControls name=DatabaseStyleControls
%% fm:meta DatabaseStyleControls desc=level 3; shown when a database/row/cell is selected; columns, sort, filters, row styling
%% fm:meta DatabaseStyleControls i0.name=emit
%% fm:meta DatabaseStyleControls i0.accepts=intent: StyleIntent
%% fm:meta DatabaseStyleControls i0.returns=void
%% fm:meta AppearanceControls name=AppearanceControls
%% fm:meta AppearanceControls desc=Appearance tile; theme, accent, and page-width presets
%% fm:meta AppearanceControls i0.name=render
%% fm:meta AppearanceControls i0.returns=JSX

%% ---- shared panel kit ----
%% fm:meta Panel name=Panel
%% fm:meta Panel desc=shared composable shell; header tiles + body + collapse toggle; reused by LeftPanel, RightPanel, Toolbar
%% fm:meta Panel state=selectedTile: string (component-local useState)
%% fm:meta Panel i0.name=render
%% fm:meta Panel i0.accepts=tiles: PanelTile[], open: boolean
%% fm:meta Panel i0.returns=JSX
%% fm:meta PanelHeader name=PanelHeader
%% fm:meta PanelHeader desc=tile tab strip; maps tile names to PanelHeaderTile
%% fm:meta PanelHeaderTile name=PanelHeaderTile
%% fm:meta PanelHeaderTile desc=one clickable tile tab; highlights when selected
%% fm:meta PanelBody name=PanelBody
%% fm:meta PanelBody desc=body list; maps items to PanelBodyItem
%% fm:meta PanelBodyItem name=PanelBodyItem
%% fm:meta PanelBodyItem desc=one clickable body row
%% fm:meta PanelToggle name=PanelToggle
%% fm:meta PanelToggle desc=collapse/expand chevron; calls toggle on the layout store

%% ---- editor shell ----
%% fm:meta Editor name=Editor
%% fm:meta Editor desc=layout shell; renders Header + WorkspaceArea + Footer and threads the manager set down
%% fm:meta Editor i0.name=render
%% fm:meta Editor i0.accepts=managers: ManagerSet
%% fm:meta Editor i0.returns=JSX
%% fm:meta Header name=Header
%% fm:meta Header desc=top bar; breadcrumb + panel toggles
%% fm:meta Footer name=Footer
%% fm:meta Footer desc=status bar; save indicator + active theme name
%% fm:meta WorkspaceEmptyState name=WorkspaceEmptyState
%% fm:meta WorkspaceEmptyState desc=centred prompt shown when the active file has no blocks; pointer-events off

%% ---- event conduit (FROZEN router) ----
%% fm:meta WorkspaceArea name=WorkspaceArea
%% fm:meta WorkspaceArea desc=pure conduit; seeds a DocDraft from the store, threads it through BM->SM->DM->LM in fixed order, commits once. Makes ZERO decisions
%% fm:meta WorkspaceArea state=wsaRef: HTMLDivElement
%% fm:meta WorkspaceArea i0.name=route
%% fm:meta WorkspaceArea i0.accepts=channel: mouse | key | lifecycle
%% fm:meta WorkspaceArea i0.accepts=data: MouseEventData | KeyEventData | LifecycleEventData
%% fm:meta WorkspaceArea i0.accepts=trigger: TriggerWord
%% fm:meta WorkspaceArea i0.returns=void
%% fm:meta WorkspaceArea i1.name=commit
%% fm:meta WorkspaceArea i1.accepts=draft: DocDraft
%% fm:meta WorkspaceArea i1.returns=void
%% fm:meta blockManager name=BlockManager
%% fm:meta blockManager desc=step 1; CRUD on TextElement + DatabaseConfiguration and styling of selected blocks; records the ids it creates on draft.created; has ZERO opinion on caret or selection
%% fm:meta blockManager state=wsaEl: HTMLElement | null
%% fm:meta blockManager i0.name=receiveMouseEvent
%% fm:meta blockManager i0.accepts=draft: DocDraft
%% fm:meta blockManager i0.returns=DocDraft
%% fm:meta blockManager i1.name=receiveKeyEvent
%% fm:meta blockManager i1.accepts=draft: DocDraft
%% fm:meta blockManager i1.returns=DocDraft
%% fm:meta blockManager i2.name=receiveLifecycleEvent
%% fm:meta blockManager i2.accepts=draft: DocDraft
%% fm:meta blockManager i2.returns=DocDraft
%% fm:meta selectionManager name=SelectionManager
%% fm:meta selectionManager desc=step 2; sole owner of ALL caret + range + multi-block selection decisions; reads draft.created.newBlockIds and independently places the caret in a newly created block (no message from BlockManager); paints CSS highlights; threads every event through ClipboardManager
%% fm:meta selectionManager state=selection: SelectionState (anchor, focus, mode)
%% fm:meta selectionManager state=wsaEl: HTMLElement | null
%% fm:meta selectionManager i0.name=receiveMouseEvent
%% fm:meta selectionManager i0.accepts=draft: DocDraft
%% fm:meta selectionManager i0.returns=DocDraft
%% fm:meta selectionManager i1.name=receiveKeyEvent
%% fm:meta selectionManager i1.accepts=draft: DocDraft
%% fm:meta selectionManager i1.returns=DocDraft
%% fm:meta selectionManager i2.name=receiveLifecycleEvent
%% fm:meta selectionManager i2.accepts=draft: DocDraft
%% fm:meta selectionManager i2.returns=DocDraft
%% fm:meta dragManager name=DragManager
%% fm:meta dragManager desc=step 3; owns the active drag gesture; writes style.top live during drag, commits final placement on drop
%% fm:meta dragManager state=activeId: string | null
%% fm:meta dragManager state=isActive: boolean
%% fm:meta dragManager state=lastLocal: Position
%% fm:meta dragManager i0.name=receiveMouseEvent
%% fm:meta dragManager i0.accepts=draft: DocDraft
%% fm:meta dragManager i0.returns=DocDraft
%% fm:meta dragManager i1.name=isDragging
%% fm:meta dragManager i1.accepts=blockId: string
%% fm:meta dragManager i1.returns=boolean
%% fm:meta layoutManager name=LayoutManager
%% fm:meta layoutManager desc=step 4 (last); resolves overlaps and re-orders document ids by position after structural changes; its output is what WSA persists
%% fm:meta layoutManager i0.name=receiveMouseEvent
%% fm:meta layoutManager i0.accepts=draft: DocDraft
%% fm:meta layoutManager i0.returns=DocDraft
%% fm:meta layoutManager i1.name=receiveKeyEvent
%% fm:meta layoutManager i1.accepts=draft: DocDraft
%% fm:meta layoutManager i1.returns=DocDraft
%% fm:meta clipboardManager name=ClipboardManager
%% fm:meta clipboardManager desc=owned by SelectionManager; stateless router that no-ops unless the trigger is copy/cut/paste
%% fm:meta clipboardManager i0.name=receiveEvent
%% fm:meta clipboardManager i0.accepts=shape: DocShape
%% fm:meta clipboardManager i0.accepts=range: SelectionPoint[]
%% fm:meta clipboardManager i0.accepts=trigger: string
%% fm:meta clipboardManager i0.returns=DocShape

%% ---- block renderers ----
%% fm:meta DragContainer name=DragContainer
%% fm:meta DragContainer desc=absolute-positioned wrapper per block; yields top ownership to DragManager while that block is dragging
%% fm:meta DragContainer i0.name=render
%% fm:meta DragContainer i0.accepts=id: string, isSelected: boolean, layoutData: LayoutData, dm: DragTargetQuery
%% fm:meta DragContainer i0.returns=JSX
%% fm:meta DragHandle name=DragHandle
%% fm:meta DragHandle desc=grab affordance; shapes a MouseEventData and forwards drag-handle-mouse-down through the conduit callback
%% fm:meta DragHandle i0.name=render
%% fm:meta DragHandle i0.accepts=id: string, cbMouseEvent: ConduitMouse
%% fm:meta DragHandle i0.returns=JSX
%% fm:meta ContentArea name=ContentArea
%% fm:meta ContentArea desc=contentEditable text block; shapes mouse/key/lifecycle events and forwards through conduit callbacks; renders nested children by id
%% fm:meta ContentArea i0.name=render
%% fm:meta ContentArea i0.accepts=activeContent: TextElement, contentDataSet: ContentDataSet
%% fm:meta ContentArea i0.returns=JSX
%% fm:meta DatabaseArea name=DatabaseArea
%% fm:meta DatabaseArea desc=database block renderer; receives its DatabaseConfiguration as a prop (no store read); renders columns + rows; holds no data
%% fm:meta DatabaseArea i0.name=render
%% fm:meta DatabaseArea i0.accepts=activeContent: TextElement, config: DatabaseConfiguration, contentDataSet: ContentDataSet
%% fm:meta DatabaseArea i0.returns=JSX
%% fm:meta DatabaseRow name=DatabaseRow
%% fm:meta DatabaseRow desc=one database row; drag handle + grid of cells; forwards events through the conduit callback
%% fm:meta DatabaseRow i0.name=render
%% fm:meta DatabaseRow i0.accepts=rowId: string, gridTemplateColumns: string, isSelected: boolean
%% fm:meta DatabaseRow i0.returns=JSX
%% fm:meta TextCell name=TextCell
%% fm:meta TextCell desc=thin adapter; maps a cell TextElement onto ContentArea so cells edit via the same contentEditable path
%% fm:meta TextCell i0.name=render
%% fm:meta TextCell i0.accepts=cell: TextElement, contentDataSet: ContentDataSet
%% fm:meta TextCell i0.returns=JSX
%% fm:meta CheckboxCell name=CheckboxCell
%% fm:meta CheckboxCell desc=read-only checkbox; click forwards database-cell-toggle; BlockManager flips the value, render reflects it
%% fm:meta CheckboxCell i0.name=render
%% fm:meta CheckboxCell i0.accepts=cell: TextElement
%% fm:meta CheckboxCell i0.returns=JSX
%% fm:meta CanvasArea name=CanvasArea
%% fm:meta CanvasArea desc=freeform canvas block (placeholder); third entry in the component registry

%% ---- block manager helpers (pure; receive DocShape, never touch stores) ----
%% fm:meta blockDefinitions name=blockDefinitions
%% fm:meta blockDefinitions desc=static block catalog; single source of truth for insertable block types
%% fm:meta blockDefinitions i0.name=findBlockDefinition
%% fm:meta blockDefinitions i0.accepts=id: string
%% fm:meta blockDefinitions i0.returns=BlockSpec | undefined
%% fm:meta databaseFactory name=databaseFactory
%% fm:meta databaseFactory desc=pure builders for a new DatabaseConfiguration and its rows
%% fm:meta databaseFactory i0.name=makeDatabaseConfig
%% fm:meta databaseFactory i0.returns=DatabaseConfiguration
%% fm:meta styleApplier name=styleApplier
%% fm:meta styleApplier desc=NEW; applies a StyleIntent to every selected TextElement on the draft DocShape; pure, no store, no DOM
%% fm:meta styleApplier i0.name=applyStyle
%% fm:meta styleApplier i0.accepts=shape: DocShape
%% fm:meta styleApplier i0.accepts=intent: StyleIntent
%% fm:meta styleApplier i0.returns=DocShape

%% ---- selection manager helpers (pure or DOM-only; receive DocShape/SelectionState) ----
%% fm:meta selectionRouter name=selectionRouter
%% fm:meta selectionRouter desc=picks the selection handler for a trigger; delegates to caret/extend/mouse handlers; pure
%% fm:meta selectionRouter i0.name=routeKey
%% fm:meta selectionRouter i0.accepts=state: SelectionState, key: KeyEventData, trigger: string, blockOrder: string[]
%% fm:meta selectionRouter i0.returns=SelectionState
%% fm:meta caretNavigation name=caretNavigation
%% fm:meta caretNavigation desc=pure caret movement for plain arrows; collapses range then moves one unit
%% fm:meta caretNavigation i0.name=arrowMove
%% fm:meta caretNavigation i0.accepts=state: SelectionState, key: KeyEventData, blockOrder: string[]
%% fm:meta caretNavigation i0.returns=SelectionState
%% fm:meta selectionExtend name=selectionExtend
%% fm:meta selectionExtend desc=pure selection extension for Shift/Cmd-Shift arrows and Select All
%% fm:meta selectionExtend i0.name=extend
%% fm:meta selectionExtend i0.accepts=state: SelectionState, key: KeyEventData, blockOrder: string[]
%% fm:meta selectionExtend i0.returns=SelectionState
%% fm:meta range name=range
%% fm:meta range desc=pure; flattens anchor/focus into an ordered SelectionPoint[] spanning the selection
%% fm:meta range i0.name=orderedSelectionRange
%% fm:meta range i0.accepts=selection: SelectionState, order: string[]
%% fm:meta range i0.returns=SelectionPoint[]
%% fm:meta shapeBuilder name=shapeBuilder
%% fm:meta shapeBuilder desc=pure; threads the snapshot into the shape and applies text deletion on Delete; returns fresh DocShape
%% fm:meta shapeBuilder i0.name=buildShape
%% fm:meta shapeBuilder i0.accepts=shape: DocShape, state: SelectionState, snapshot: SelectionSnapshot, deleteSelection: boolean
%% fm:meta shapeBuilder i0.returns=DocShape
%% fm:meta highlightRenderer name=highlightRenderer
%% fm:meta highlightRenderer desc=paints selection via the CSS Custom Highlight API; DOM paint only, no React state, no store
%% fm:meta highlightRenderer i0.name=renderSelectionHighlight
%% fm:meta highlightRenderer i0.accepts=state: SelectionState, blockOrder: string[], wsaEl: HTMLElement | null
%% fm:meta highlightRenderer i0.returns=void
%% fm:meta domHelpers name=domHelpers
%% fm:meta domHelpers desc=the ONLY module that reads the DOM; returns plain values (point<->offset, block text); never a setter, never a store
%% fm:meta domHelpers i0.name=pointToPosition
%% fm:meta domHelpers i0.accepts=clientX: number, clientY: number
%% fm:meta domHelpers i0.returns=SelectionPoint

%% ---- layout manager helpers (pure; receive DocShape/LayoutDataSet) ----
%% fm:meta workspaceLayout name=workspaceLayout
%% fm:meta workspaceLayout desc=measures live block heights and orchestrates add/delete collision resolution; reads DOM, never a store
