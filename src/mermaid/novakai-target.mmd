%% ---- value objects / data tables ----
%% fm:meta docDraft name=DocDraft
%% fm:meta docDraft desc=the conduit payload; committed currentReadOnly slices + proposed slices per channel; built by WSA, threaded through every manager
%% fm:meta docDraft state=dataSet: DraftChannel of file/content/layout/database
%% fm:meta docDraft state=selection: currentBlocks + proposedBlocks + caret
%% fm:meta docDraft state=created: newBlockIds (BlockManager writes, SelectionManager reads to place the caret)
%% fm:meta docShape name=DocShape
%% fm:meta docShape desc=the flat effective view (proposed ?? current) every manager and helper reads and returns
%% fm:meta docShape state=file: FileData | null
%% fm:meta docShape state=contentData: ContentDataSet
%% fm:meta docShape state=layoutData: LayoutDataSet
%% fm:meta docShape state=databaseData: DatabaseDataSet
%% fm:meta docShape state=selection: SelectionSnapshot
%% fm:meta componentRegistry name=COMPONENT_REGISTRY
%% fm:meta componentRegistry desc=data table mapping TextElement.component to its renderer; a lookup, never a branch
%% fm:meta cellRegistry name=CELL_REGISTRY
%% fm:meta cellRegistry desc=data table mapping DbColumnType to its cell renderer; a lookup, never a branch

