%% fm:meta workspaceLayout i0.returns=layouts: LayoutDataSet, content: string[]
%% fm:meta collisionManager name=collisionManager
%% fm:meta collisionManager desc=pure; sorts a file's placements by y and pushes overlapping blocks down flush
%% fm:meta collisionManager i0.name=resolveCollisions
%% fm:meta collisionManager i0.accepts=items: LayoutItem[], movedBlockId: string
%% fm:meta collisionManager i0.returns=LayoutItem[]
%% fm:meta grid name=grid
%% fm:meta grid desc=pure; grid constants and snap helpers (GRID_UNIT, PAGE_X, snapToGrid)
%% fm:meta grid i0.name=snapToGrid
%% fm:meta grid i0.accepts=px: number
%% fm:meta grid i0.returns=number

%% ---- clipboard helpers (pure on DocShape; buffer is the clipboard's own) ----
%% fm:meta copy name=copy
%% fm:meta copy desc=collects selected blocks into the clipboard buffer; never mutates the document
