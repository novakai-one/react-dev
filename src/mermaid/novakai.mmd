  main(["main.tsx"])
  Login("Login")

  subgraph appShell ["App shell"]
    App["App"]
    LeftPanel["LeftPanel"]
    RightPanel["RightPanel"]
  end

  subgraph conduit ["Event conduit"]
    Editor["Editor"]
    WorkspaceArea["WorkspaceArea"]
    blockManager("BlockManager")
    selectionManager("NewSelectionManager")
    dragManager("DragManager")
    layoutManager("LayoutManager")
    clipboardManager("ClipboardManager")
  end

  subgraph blockRenderers ["Block renderers"]
    DragContainer["DragContainer"]
    ContentArea["ContentArea"]
    DatabaseArea["DatabaseArea"]
  end

  subgraph stateStores ["Zustand stores"]
    workspaceStore[("useWorkspaceStore")]
    authStore[("useAuthStore")]
    themeStore[("useThemeStore")]
    layoutStore[("useLayoutStore")]
    blockEventStore[("useBlockEventStore")]
  end

  subgraph persistence ["Persistence"]
    documentStorage["useDocumentStorage"]
    supabase{{"Supabase"}}
  end

  main --> App
  App -->|1| LeftPanel
  App -->|2| Editor
  App -->|3| RightPanel
  Editor --> WorkspaceArea
  WorkspaceArea -->|1| blockManager
  WorkspaceArea -->|2| selectionManager
  WorkspaceArea -->|3| dragManager
  WorkspaceArea -->|4| layoutManager
  WorkspaceArea --> DragContainer
  DragContainer --> ContentArea
  DragContainer --> DatabaseArea
  selectionManager --> clipboardManager
  App -.->|auth guard| Login
  App -.->|reads status| authStore
  App -.->|loads on sign-in| documentStorage
  App -.->|hydrates on sign-in| themeStore
  App -.->|reads page width| layoutStore
  WorkspaceArea -.->|seeds + commits| workspaceStore
  WorkspaceArea -.->|saves| documentStorage
  blockManager -.->|sets pendingFocus| workspaceStore
  LeftPanel -.->|reads files| workspaceStore
  LeftPanel -.->|saves new file| documentStorage
  LeftPanel -.->|dispatches via| blockEventStore
  blockEventStore -.->|forwards to router| WorkspaceArea
  LeftPanel -.->|reads open state| layoutStore
  RightPanel -.->|reads open state| layoutStore
  authStore -.->|session listener| supabase
  documentStorage -.->|upserts doc| supabase
  themeStore -.->|upserts theme| supabase
